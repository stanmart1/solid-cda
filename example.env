# Server Configuration
PORT=3000
NODE_ENV=development # or production

# MongoDB Configuration
MONGODB_URI=mongodb://your_mongodb_user:your_mongodb_password@your_mongodb_host:27017/your_database_name

# JWT Configuration
JWT_SECRET=your_super_strong_jwt_secret_key_please_change_this

# Payment Configuration
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key_here
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key_here
FLUTTERWAVE_ENCRYPTION_KEY=your_flutterwave_encryption_key_here
FLUTTERWAVE_WEBHOOK_SECRET_HASH=your_flutterwave_webhook_secret_hash_here
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_REDIRECT_URL=http://localhost:3000/your_frontend_payment_callback_url # Adjust as needed

# Paystack Configuration
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here
PAYSTACK_CALLBACK_URL=http://localhost:3000/api/payments/paystack/callback # Adjust if your server runs elsewhere
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret_here


BANK_TRANSFER_BANK_NAME="Your CDA Bank Name"
BANK_TRANSFER_ACCOUNT_NUMBER="Your CDA Bank Account Number"
BANK_TRANSFER_ACCOUNT_NAME="Your CDA Account Name"

DEFAULT_CURRENCY="NGN" # Or your preferred currency
TRANSACTION_PREFIX="CDA" # Prefix for transaction references

# Notification Configuration
# For Ethereal Email (testing) - generate at https://ethereal.email/create
# For production, use your actual SMTP provider details
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your_ethereal_user@ethereal.email
EMAIL_PASS=your_ethereal_password
EMAIL_FROM="CDA Platform <noreply@yourdomain.com>"

# For BulkSMS (example, replace with your provider's details)
BULKSMS_API_KEY=your_bulksms_api_key_or_token
BULKSMS_SENDER_ID="CDAPLATFORM" # Or your registered Sender ID
BULKSMS_BASE_URL=https://api.bulksmsnigeria.com/api/v1 # Example, change if different

# For Firebase Cloud Messaging (Push Notifications) - Placeholder
FCM_SERVER_KEY=your_fcm_server_key_here

# Application Base URL (used for generating links in emails, etc.)
APP_BASE_URL=http://localhost:3000 # Change to your production URL

# Placeholder for System User ID (for automated accounting entries)
# Create a dedicated user in your DB for system actions and use its ObjectId here.
# Example: SYSTEM_USER_ID=60c72b9f9b1e8a3f8c8d6e5g (replace with actual ObjectId)
SYSTEM_USER_ID=000000000000000000000000 # Replace with a real ObjectId of a system user
